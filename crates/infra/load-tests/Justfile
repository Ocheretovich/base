# Load test runner - transaction spamming for network load testing
#
# Usage:
#   just load-test devnet                         - Load test local devnet (uses Anvil Account #1)
#   FUNDER_KEY=0x... just load-test sepolia-alpha - Load test sepolia-alpha
#   FUNDER_KEY=0x... just load-test sepolia       - Load test sepolia

set positional-arguments := true
set working-directory := '../../..'

# Show load-test commands
default:
    @just load-test --list

# Run load test against devnet (local) - uses Anvil Account #1
devnet:
    FUNDER_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d cargo run -p base-load-tests --example load_test -- crates/infra/load-tests/examples/devnet.yaml

# Run load test against sepolia-alpha network (requires FUNDER_KEY env var)
sepolia-alpha:
    cargo run -p base-load-tests --example load_test -- crates/infra/load-tests/examples/sepolia-alpha.yaml

# Run load test against sepolia network (requires FUNDER_KEY env var)
sepolia:
    cargo run -p base-load-tests --example load_test -- crates/infra/load-tests/examples/sepolia.yaml
